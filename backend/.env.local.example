# Local overrides — NEVER commit .env.local
# Copy: cp .env.local.example .env.local
# Overrides .env for secrets, adapter choice (e.g. EMAIL_ADAPTER=ches), etc.

# Optional: quieter logs in local dev
# LOG_LEVEL=debug

# CHES (Common Hosted Email Service)
# CHES_CLIENT_ID=
# CHES_CLIENT_SECRET=

# Adapter overrides (optional — e.g. use CHES instead of nodemailer locally)
# EMAIL_ADAPTER=ches

# Workspace auth bootstrap (local only — do not set in production)
AUTH_BOOTSTRAP_PATH=config/workspace-auth.bootstrap.example.json
